# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: apply household migration from the terminal (npm run apply:household-migration)
# Supabase Dashboard → Project Settings → Database → Connection string (URI)
# SUPABASE_DB_URL=postgresql://postgres:YOUR-PASSWORD@db.YOUR-PROJECT-REF.supabase.co:5432/postgres
# Or set only the password (project ref comes from NEXT_PUBLIC_SUPABASE_URL):
# SUPABASE_DB_PASSWORD=your-database-password

# Auth setup (Supabase Dashboard → Authentication → Providers):
# 1. Enable Email provider
# 2. Disable anonymous sign-ins (optional, recommended for production)
# 3. Configure Site URL and redirect URLs for your app origin
#
# Database:
# Run supabase/schema.sql in the Supabase SQL editor before first use.
# RLS policies scope all finance tables to auth.uid() = user_id.
