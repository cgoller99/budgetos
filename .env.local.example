# Buxme Production Environment Template
# Copy to .env.local and fill in values from Vercel Production:
#   vercel env pull .env.local --environment=production

# ── Supabase (required) ──────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: run migrations from terminal (npm run apply:*-migration)
# SUPABASE_DB_URL=postgresql://postgres:YOUR-PASSWORD@db.YOUR-PROJECT.supabase.co:5432/postgres
# SUPABASE_DB_PASSWORD=

# ── Site ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://buxme.co

# ── Plaid Production ─────────────────────────────────────────────────────────
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=production
PLAID_TOKEN_ENCRYPTION_KEY=
PLAID_WEBHOOK_URL=https://buxme.co/api/plaid/webhook
NEXT_PUBLIC_PLAID_ENABLED=true

# ── Stripe Live Mode ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_
STRIPE_WEBHOOK_SECRET=whsec_
STRIPE_PRO_PRICE_ID=price_
STRIPE_PRO_PLUS_PRICE_ID=price_
# Optional yearly prices (checkout falls back to product yearly price if omitted)
# STRIPE_PRO_YEARLY_PRICE_ID=price_
# STRIPE_PRO_PLUS_YEARLY_PRICE_ID=price_
# Optional product ID fallbacks if price IDs rotate:
# STRIPE_PRO_PRODUCT_ID=prod_
# STRIPE_PRO_PLUS_PRODUCT_ID=prod_
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_
NEXT_PUBLIC_STRIPE_ENABLED=true
NEXT_PUBLIC_STRIPE_PRO_PRICE=$7.99
NEXT_PUBLIC_STRIPE_PRO_PLUS_PRICE=$14.99

# ── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_
RESEND_FROM_EMAIL=noreply@buxme.co
RESEND_FROM_NAME=Buxme
# Optional: Resend sandbox testing only
# RESEND_SANDBOX_ACCOUNT_EMAIL=you@example.com

# ── Analytics (PostHog) ──────────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── Security & access ────────────────────────────────────────────────────────
CRON_SECRET=
ADMIN_EMAILS=admin@buxme.co
FOUNDER_EMAILS=founder@buxme.co

# ── Optional dev tooling ─────────────────────────────────────────────────────
# SUPABASE_ACCESS_TOKEN=
