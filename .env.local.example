# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Auth setup (Supabase Dashboard → Authentication → Providers):
# 1. Enable Email provider
# 2. Disable anonymous sign-ins (optional, recommended for production)
# 3. Configure Site URL and redirect URLs for your app origin
#
# Database:
# Run supabase/schema.sql in the Supabase SQL editor before first use.
# RLS policies scope all finance tables to auth.uid() = user_id.
